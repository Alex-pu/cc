NODE_ENV=development
PORT=4000
HOST=0.0.0.0
VITE_API_BASE_URL=http://localhost:4000

# Keep real Neon credentials in .env only.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&channel_binding=require

# Vite/frontend uses VITE_NEON_AUTH_URL. The backend keeps the same value without VITE_.
NEON_AUTH_URL=https://YOUR_NEON_AUTH_HOST/neondb/auth
NEON_AUTH_JWKS_URL=https://YOUR_NEON_AUTH_HOST/.well-known/jwks.json
NEON_AUTH_JWT_ISSUER=
NEON_AUTH_JWT_AUDIENCE=

# Frontend hosted auth links from Neon Auth.
VITE_NEON_AUTH_SIGN_IN_URL=
VITE_NEON_AUTH_SIGN_UP_URL=
VITE_NEON_AUTH_SIGN_OUT_URL=

# MVP contact/payment settings.
ADMIN_CONTACT_PHONE=0704813341
PAYMENTS_ENABLED=true

# Paystack wallet top-ups.
PAYSTACK_SECRET_KEY=
PAYSTACK_CURRENCY=KES
PAYSTACK_CALLBACK_URL=

# Cloudinary-only image storage. The app signs uploads and stores image URLs/keys in Postgres.
# No local image uploads are stored on the server.
CLOUDINARY_URL=cloudinary://YOUR_API_KEY:YOUR_API_SECRET@YOUR_CLOUD_NAME
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=staffmarket

# Comma-separated list. Example: http://localhost:5173,http://localhost:3000
CORS_ORIGINS=http://localhost:5173

LOG_LEVEL=info
